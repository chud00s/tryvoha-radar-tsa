# Copy to .env and fill in. The pipeline runs WITHOUT any of these
# (rule-based fallback + committed caches), but they unlock full features.

# Anthropic API key — enables LLM event extraction (claude-haiku-4-5).
# Get one at https://console.anthropic.com/. Extraction cost is ~cents.
ANTHROPIC_API_KEY=

# Optional: alerts.in.ua token for the "live current state" panel.
# Request at https://devs.alerts.in.ua/
ALERTS_IN_UA_TOKEN=

# Optional: Telegram API credentials for LIVE OSINT ingestion (Telethon).
# Create an app at https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Comma-separated public channels to read, e.g. some_osint_channel,another_channel
TELEGRAM_CHANNELS=
