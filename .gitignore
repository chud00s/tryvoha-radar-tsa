# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Env / secrets
.env
# Telethon session files = live, authenticated Telegram account credentials — never commit.
# (Inline comments are NOT stripped in .gitignore, so the pattern must be on its own line.)
*.session
*.session-journal

# Large raw data — downloaded CSV is ignored; geojson + sample_messages.json are committed
data/raw/*.csv

# OS / editor
.DS_Store
.ipynb_checkpoints/
.idea/
.vscode/

# Local-only Stage-2 submission artifact (full AI conversation log) + its generator.
# Submitted via the application form — intentionally NOT published in the public repo.
docs/AI_LOG.*
scripts/export_chat_log.py
